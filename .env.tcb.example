# 腾讯云开发（TCB）配置
# 复制此文件为 .env.local 并填入实际值

# ===== 必填：云开发环境 =====
VITE_TCB_ENV_ID=chengjileida-8gpex74ea92afd85

# ===== 可选：认证开关 =====
VITE_ENABLE_TCB_AUTH=true

# ===== 云函数环境变量（在腾讯云控制台设置，不放在前端 .env 中）=====
# TENCENT_SECRET_ID=你的腾讯云SecretId
# TENCENT_SECRET_KEY=你的腾讯云SecretKey
# SMS_APPID=短信应用ID
# SMS_SIGNNAME=短信签名（如"成绩雷达"）
# TEMPLATE_CODE=短信模板ID
